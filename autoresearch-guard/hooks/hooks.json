{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ./hooks/pre_tool_command_gate.py",
            "timeout": 10,
            "statusMessage": "Checking AutoResearch Guard command policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ./hooks/post_tool_capture.py",
            "timeout": 10,
            "statusMessage": "Checking AutoResearch Guard evidence reminder"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ./hooks/stop_goal_guard.py",
            "timeout": 10,
            "statusMessage": "Checking AutoResearch Guard closure"
          }
        ]
      }
    ]
  }
}
