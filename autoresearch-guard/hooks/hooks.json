{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/hooks/session_recovery.py\"",
            "timeout": 10,
            "statusMessage": "Loading AutoResearch Guard recovery state",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\hooks\\session_recovery.py\""
          }
        ]
      }
    ]
  }
}
