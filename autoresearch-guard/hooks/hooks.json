{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/hooks/pre_tool_command_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking AutoResearch Guard command policy",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\hooks\\pre_tool_command_gate.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/hooks/post_tool_capture.py\"",
            "timeout": 10,
            "statusMessage": "Checking AutoResearch Guard evidence reminder",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\hooks\\post_tool_capture.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/hooks/stop_goal_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking AutoResearch Guard closure",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\hooks\\stop_goal_guard.py\""
          }
        ]
      }
    ]
  }
}
